# =============================================================================
# AI Credits Tracker — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your credentials.
# All variables are optional — only configure the services you use.
# In Railway, set these in the Variables tab instead of a .env file.
# =============================================================================


# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------

# Port to bind uvicorn (Railway sets this automatically — do not override)
# PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# TIER 1 — OFFICIAL API PROVIDERS
# These use documented, stable API endpoints.
# -----------------------------------------------------------------------------

# OpenRouter — https://openrouter.ai/settings/keys
# Create an API key and paste it here.
# Endpoint: GET https://openrouter.ai/api/v1/key
# Returns: credit balance, usage, rate limits
OPENROUTER_API_KEY=

# OpenAI — https://platform.openai.com/settings/organization/admin-keys
# IMPORTANT: Must be an Admin key (sk-admin-...), NOT a regular API key.
# Regular keys (sk-...) will return a 403 error.
# Endpoint: GET https://api.openai.com/v1/organization/costs
# Returns: 30-day spend (OpenAI has no direct balance/credits endpoint)
OPENAI_ADMIN_KEY=

# xAI (Grok) — https://console.x.ai → Settings → Management Keys
# You also need your Team ID from the console URL or account settings.
# Endpoint: GET https://api.x.ai/v1/api-key
# Returns: prepaid credit balance
XAI_MANAGEMENT_KEY=
XAI_TEAM_ID=


# -----------------------------------------------------------------------------
# TIER 2 — SESSION-BASED PROVIDERS
# These use undocumented or internal console APIs accessed via session cookies.
# Balances may break if the provider changes their internal API.
# Refresh intervals are longer (30 min) to avoid rate limiting.
# -----------------------------------------------------------------------------

# Anthropic — https://platform.claude.com
# How to get credentials:
#   1. Log in to platform.claude.com
#   2. Open DevTools (F12) → Network tab
#   3. Refresh the page and find a request to /api/organizations/...
#   4. Copy the org ID from the URL path
#   5. In the request headers, copy the full Cookie header value
#      (look for the sessionKey=... cookie)
# Endpoint: GET https://platform.claude.com/api/organizations/{org_id}/prepaid/credits
ANTHROPIC_SESSION_COOKIE=
ANTHROPIC_ORG_ID=

# Mistral AI — https://console.mistral.ai
# How to get credentials:
#   1. Log in to console.mistral.ai
#   2. Open DevTools (F12) → Network → any authenticated request
#   3. Copy the full Cookie header value
# Endpoint: GET https://console.mistral.ai/api/billing (session-scraped)
MISTRAL_SESSION_COOKIE=

# Groq — https://console.groq.com
# How to get credentials:
#   1. Log in to console.groq.com
#   2. Open DevTools (F12) → Network → any authenticated request
#   3. Copy the full Cookie header value
# Endpoint: GET https://console.groq.com/api/billing (session-scraped)
GROQ_SESSION_COOKIE=

# Manus — https://manus.im
# Option A: API Key (preferred if available in your account settings)
# Option B: Session Cookie from browser DevTools
#   1. Log in to manus.im
#   2. Open DevTools (F12) → Network → any authenticated request
#   3. Copy the full Cookie header value
MANUS_API_KEY=
MANUS_SESSION_COOKIE=

# Warp — https://app.warp.dev
# How to get credentials:
#   1. Log in to app.warp.dev
#   2. Open DevTools (F12) → Network → any authenticated request
#   3. Copy the full Cookie header value
# Note: Warp has no public billing API (see github.com/warpdotdev/warp/issues/8405)
WARP_SESSION_COOKIE=
