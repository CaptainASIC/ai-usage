# =============================================================================
# AI Credits Tracker — Environment Variables
# =============================================================================
# Copy this file to .env for local development.
# For Railway: add these in the Variables tab of each service.
#
# ⚠️  Never commit your real .env to version control.
# =============================================================================


# ─── Backend Service (set in Railway BACKEND service) ────────────────────────

# Port to bind uvicorn. Railway sets this automatically — do not override.
# PORT=8000

# CORS: comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=https://your-frontend.railway.app,http://localhost:5173

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# ─── Frontend Service (set in Railway FRONTEND service) ──────────────────────

# URL of the deployed backend API.
VITE_API_URL=https://your-backend.railway.app


# =============================================================================
# AI PROVIDERS
# =============================================================================

# OpenRouter — https://openrouter.ai/settings/keys
# Standard API key (sk-or-v1-...).
# Balance is read from /api/v1/credits (prepaid accounts).
OPENROUTER_API_KEY=

# OpenAI — https://platform.openai.com/settings/organization/admin-keys
# ⚠️  Must be an Admin key (sk-admin-...), NOT a regular API key (sk-...).
# Shows 30-day spend only — OpenAI has no balance endpoint.
OPENAI_ADMIN_KEY=

# Anthropic — https://console.anthropic.com
# Session cookie: platform.claude.com → DevTools → Application → Cookies → sessionKey
# Org ID: from the URL at console.anthropic.com/settings/organization
ANTHROPIC_SESSION_COOKIE=
ANTHROPIC_ORG_ID=

# xAI (Grok) — https://console.x.ai/settings
# Management key (xai-...) + Team ID from the console.
XAI_MANAGEMENT_KEY=
XAI_TEAM_ID=

# Mistral AI — https://console.mistral.ai
# Session cookie: DevTools → Application → Cookies (full cookie header string)
MISTRAL_SESSION_COOKIE=

# Groq — https://console.groq.com
# Session cookie: DevTools → Application → Cookies (full cookie header string)
GROQ_SESSION_COOKIE=

# Manus — https://manus.im
# JWT Bearer token from the Manus web app:
#   1. Open manus.im in your browser and log in
#   2. DevTools (F12) → Network tab → filter by 'api.manus.im'
#   3. Click any request → Headers → Authorization → copy value after 'Bearer '
# Uses Connect RPC endpoints: /user.v1.UserService/WebdevUsageInfo
MANUS_API_KEY=

# Warp — https://app.warp.dev
# Session cookie: DevTools → Application → Cookies (full cookie header string)
# Note: No public billing API (see github.com/warpdotdev/warp/issues/8405)
WARP_SESSION_COOKIE=

# Plaud — https://web.plaud.ai
# JWT token: DevTools Console → localStorage.getItem('tokenstr')
# Token is long-lived (~10 months). Do not include "Bearer " prefix.
PLAUD_JWT_TOKEN=

# Gemini (Google AI Studio) — https://aistudio.google.com/app/apikey
# Standard Gemini API key (AIza...).
# Note: No balance endpoint — shows key validity only.
# For spend tracking, configure the GCP provider below.
GEMINI_API_KEY=


# =============================================================================
# CLOUD PROVIDERS
# =============================================================================

# Railway — https://railway.app/account/tokens
# ⚠️  Use RAILWAY_CREDIT_TOKEN (NOT RAILWAY_API_KEY — Railway injects that automatically).
# Personal API token for reading credit balance via GraphQL API.
RAILWAY_CREDIT_TOKEN=

# Vercel — https://vercel.com/account/tokens
# Personal access token. VERCEL_TEAM_ID is optional (for team accounts).
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=

# mem0 — https://app.mem0.ai/dashboard/api-keys
# API key (m0-...).
# Note: No billing API — shows key validity and memory count.
MEM0_API_KEY=

# Neon DB — https://console.neon.tech/app/settings/api-keys
# API key for reading compute consumption.
# Note: Consumption API requires Launch plan or above.
NEON_API_KEY=

# RunPod — https://runpod.io/console/user/settings → API Keys
# API key for reading credit balance and billing history.
RUNPOD_API_KEY=

# AWS — https://console.aws.amazon.com/iam
# IAM user credentials with ce:GetCostAndUsage permission.
# Shows month-to-date spend via Cost Explorer.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# GCP — https://console.cloud.google.com/iam-admin/serviceaccounts
# Service account with roles/billing.viewer.
# GCP_SERVICE_ACCOUNT_JSON: paste the full contents of the downloaded JSON key file.
# GCP_BILLING_ACCOUNT_ID: from console.cloud.google.com/billing (format: XXXXXX-XXXXXX-XXXXXX)
GCP_SERVICE_ACCOUNT_JSON=
GCP_BILLING_ACCOUNT_ID=
