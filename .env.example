# AI Credits Tracker - Environment Variables
# Copy this file to .env and fill in your credentials
# All values are optional - only configure the services you use

# ============================================================
# Tier 1: Official API Support (most reliable)
# ============================================================

# OpenRouter
# Get your API key from: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# OpenAI
# Create an Admin key at: https://platform.openai.com/settings/organization/admin-keys
# Note: Shows 30-day spend, not remaining balance (no balance API available)
OPENAI_ADMIN_KEY=

# xAI (Grok)
# Create a Management Key at: https://console.x.ai → Settings
# Also requires your Team ID (found in the console URL)
XAI_MANAGEMENT_KEY=
XAI_TEAM_ID=

# ============================================================
# Tier 2: Session Cookie / Undocumented API
# These require manual extraction from your browser DevTools
# ============================================================

# Anthropic
# 1. Log in to https://platform.claude.com
# 2. Open DevTools → Network → find a request to /api/organizations/...
# 3. Copy org_id from URL and sessionKey from Cookie header
ANTHROPIC_ORG_ID=
ANTHROPIC_SESSION_COOKIE=

# Mistral AI
# 1. Log in to https://console.mistral.ai
# 2. Open DevTools → Application → Cookies
# 3. Copy the full cookie string
MISTRAL_SESSION_COOKIE=

# Groq
# 1. Log in to https://console.groq.com
# 2. Open DevTools → Application → Cookies
# 3. Copy the full cookie string
GROQ_SESSION_COOKIE=

# Manus
# 1. Log in to https://manus.im
# 2. Open DevTools → Network → find API requests
# 3. Copy the Authorization Bearer token or Cookie header
MANUS_SESSION_COOKIE=
MANUS_API_KEY=

# Warp
# 1. Log in to https://app.warp.dev
# 2. Open DevTools → Application → Cookies
# 3. Copy the full cookie string
WARP_SESSION_COOKIE=

# ============================================================
# Application Settings
# ============================================================

# Port (Railway sets this automatically)
PORT=8000
