{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "node": "22"
  },
  "steps": {
    "build": {
      "commands": [
        "npm install -g pnpm --silent",
        "cd frontend && pnpm install --frozen-lockfile && pnpm build"
      ]
    }
  },
  "deploy": {
    "startCommand": "uv run uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}"
  }
}
